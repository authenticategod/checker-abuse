    "https://www.skittenz.com": {
      "product": {
        "id": 9844322533695,
        "title": "Snowy Aspens",
        "handle": "afternoon-light-copy-1",
        "body_html": "<p><br></p>\n<ul data-mce-fragment=\"1\">\n<li data-mce-fragment=\"1\">Skins: <meta charset=\"utf-8\"> <span data-mce-fragment=\"1\">This is a\u00a0<strong data-mce-fragment=\"1\">SKIN</strong>\u00a0for your glove or mitten.\u00a0</span><span data-mce-fragment=\"1\">A</span><span data-mce-fragment=\"1\">\u00a0glove or mitten is\u00a0<span data-mce-fragment=\"1\" style=\"text-decoration: underline;\"><strong data-mce-fragment=\"1\">NOT</strong></span> included <meta charset=\"utf-8\">(see <a rel=\"noopener\" href=\"https://www.instagram.com/skittenzmittens/\" target=\"_blank\">@skittenzmittens)</a>.</span>\n</li>\n</ul>\n<p>\u00a0</p>\n<ul data-mce-fragment=\"1\">\n<li data-mce-fragment=\"1\">Snowy Aspens are a collaboration with local artist Jesse Crock who is also based in Golden, CO. A portion of proceeds from all Skittenz featuring Jesse's work are returned directly back to him. Learn more about Jesse in his <a href=\"https://www.skittenz.com/pages/artist-bio-jesse-crock\" rel=\"noopener\" target=\"_blank\">bio</a> and see more of his artwork at <a href=\"https://jessecrockart.com/\" rel=\"noopener\" target=\"_blank\">jessecrockart.com</a> and follow him on Instagram\u00a0<a href=\"https://www.instagram.com/jesse_crock_art/\" rel=\"noopener\" target=\"_blank\">@jesse_crock_art</a><br>\n</li>\n</ul>\n<p>\u00a0</p>\n<ul data-mce-fragment=\"1\">\n<li data-mce-fragment=\"1\">Lightweight: Designed for skiers and snowboarders, Skittenz are ultra-lightweight, adding no bulk to your gloves or mittens.</li>\n<li data-mce-fragment=\"1\">Premium Protection: Skittenz provide\u00a0an extra layer of\u00a0protection for your existing gloves or mittens, preserving their durability and extending their lifespan.</li>\n<li data-mce-fragment=\"1\">NikWax\u00ae Coating:\u00a0Protected with NikWax technology, keep your gloves or mittens shielded from moisture and wet snow.</li>\n<li data-mce-fragment=\"1\">Snow Defense: Skittenz create a barrier against snow entering your glove's cuff.</li>\n<li data-mce-fragment=\"1\">\n<meta charset=\"utf-8\"> <span data-mce-fragment=\"1\">Visibility Boost: Stand out on the mountain, making you more visible to friends and family.</span>\n</li>\n<li data-mce-fragment=\"1\">Possible Speed Boost: Skittenz may make you look a little faster - if you actually read this far you deserve to smile.</li>\n</ul>\n<p>\u00a0</p>\n<ul data-mce-fragment=\"1\">\n<li data-mce-fragment=\"1\">What size should you buy?</li>\n<ul>\n<li data-mce-fragment=\"1\">Please see our <a href=\"https://www.skittenz.com/pages/sizing-guide\" title=\"Skittenz sizing guide\" target=\"_blank\">sizing guide</a><br>\n</li>\n</ul>\n</ul>",
        "published_at": "2025-01-06T19:21:00-07:00",
        "created_at": "2025-01-06T19:20:26-07:00",
        "updated_at": "2026-04-02T12:53:05-06:00",
        "vendor": "Skittenz",
        "product_type": "",
        "tags": [],
        "variants": [
          {
            "id": 50202321846591,
            "title": "Medium - Mitten Not Included",
            "option1": "Medium - Mitten Not Included",
            "option2": null,
            "option3": null,
            "sku": "SNOW-M-2024",
            "requires_shipping": true,
