    "https://www.fauxwine.com": {
      "product": {
        "id": 8144103309621,
        "title": "Faux Wine Melange Ros\u00e9",
        "handle": "melange-rose",
        "body_html": "<p><em>Alcohol-free, crafted from verjus, fruit, and botanicals.</em></p>\n<p data-start=\"296\" data-end=\"423\">Melange Ros\u00e9 is crafted from verjus, fruit, and botanicals for a profile defined by brightness, softness, and expressive fruit.</p>\n<p data-start=\"425\" data-end=\"582\">Lifted acidity leads the experience, creating a fresh, balanced structure. Notes of raspberry and peach unfold alongside subtle citrus and delicate hibiscus.</p>\n<p data-start=\"584\" data-end=\"686\">On the palate, gentle fruit expression brings roundness while maintaining a dry, refreshing character.</p>\n<p data-start=\"688\" data-end=\"770\">The finish is light, elegant, and quietly layered, designed for ease at the table.</p>\n<p><br></p>",
        "published_at": "2023-02-22T14:03:15-05:00",
        "created_at": "2023-02-22T14:03:15-05:00",
        "updated_at": "2026-04-02T14:53:08-04:00",
