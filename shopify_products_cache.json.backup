    "https://element-tattoo-supplies.myshopify.com": {
      "product": {
        "id": 9164469895395,
        "title": "AQUA Cartridges Curved Magnums LT 10 count",
        "handle": "aqua-curved-magnums-lt-cartridges-10ct",
        "body_html": "<p>Top 3 reasons to use the AVA Aqua Cartridges\u00a0</p>\n<p>- Finger rest cushion for maximum comfort, grip and control.<br><meta charset=\"utf-8\">- Needle is sharper, easier penetrate the ink into the skin, reduce skin lesions.<br><meta charset=\"utf-8\">- The needles fits more tightly to the tips, so it doesn't vibrate while tattooing</p>\n<div class=\"page\" title=\"Page 20\">\n<div class=\"section\">\n<div class=\"layoutArea\">\n<div class=\"column\">\n<ul>\n<li><span>Reinforce Membrane, more accurate positioning and ink absorption.</span></li>\n<li><span>Best 316L Germany Hardness Steel, less needle wear</span></li>\n<li><span>Good Soldering process, flat surface and look bright.</span></li>\n<li><span>All needles\u00a0are EO GAS Sterilize, safe to use.</span></li>\n<li><span>10 count box</span></li>\n</ul>\n<p><strong>Needle Taper Guide</strong><br>LT = Long Taper (5.5mm)<br><span>MT = Medium Taper (3.5mm)<br></span></p>\n<p><span><strong>Needle Diameter Guide</strong><br>#12 = Standard, 0.35mm<br>#10 = Bugpin, 0.10mm<br></span><span></span></p>\n</div>\n</div>\n</div>\n</div>\n<ul class=\"ul1\"></ul>\n<ul class=\"ul1\"></ul>",
        "published_at": "2026-03-02T20:10:29-08:00",
        "created_at": "2026-03-02T20:08:38-08:00",
        "updated_at": "2026-04-02T10:59:45-07:00",
        "vendor": "AVA Machine",
        "product_type": "Cartridge Needle",
