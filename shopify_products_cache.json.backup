    "https://www.rothys.com": {
      "product": {
        "id": 7575209279582,
        "title": "The Mini Loafer (for Kids) - Sorbet Stripe",
        "handle": "kids-mini-loafer-sorbet-stripe",
        "body_html": "<h1 class=\"p1\">The Mini Loafer in Sorbet Stripe</h1>\n<p><br></p>\n<ul>\n<li>Ivory upper with bright pink stripes.</li>\n<li>Soft, bendy and comfy\u2014built for kids\u2019 little adventures.</li>\n<li>Bright pink heel tab makes slipping on (and off) a breeze for kids.</li>\n<li>Bright pink piping along the outsole adds a fun pop of color.</li>\n<li>Tan rubber outsole with extra traction for every hop, skip and jump.</li>\n</ul>",
        "published_at": "2026-03-31T05:53:03-07:00",
        "created_at": "2026-02-20T15:11:54-08:00",
