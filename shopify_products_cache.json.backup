    "https://youre-on-the-money.myshopify.com": {
      "product": {
        "id": 4937073328264,
        "title": "Donald Trump (smiling) on a REAL Dollar Bill (Full Color)",
        "handle": "donald-trump-on-a-real-dollar-bill-full-color",
        "body_html": "It's the 45th president of the United States on a real dollar bill!<br><br>\n<p><strong>Yes, they\u2019re real. And, yes, they\u2019re legal.</strong></p>\n<p><em>You\u2019re on the Money</em>\u00a0custom dollar bills are genuine U.S. currency, mint and uncirculated. The process of affixing diecut labels\u00a0over George Washington using nonpermanent adhesive is perfectly legal and permitted by the Secret Service and Treasury Department. The bills are not damaged or defaced in any way.</p>\n<p><span>All</span><span>\u00a0</span><em>You\u2019re on the Money</em><span>\u00a0</span><span>custom dollar bills\u00a0come in clear protective vinyl sleeves.</span></p>\n<p><strong>Satisfaction is 100% GUARANTEED or your money back.\u00a0</strong>All\u00a0<em>You\u2019re on the Money</em>\u00a0custom dollar bills\u00a0come in clear protective vinyl sleeves and are shipped via U.S. Mail within two business days.</p>\n<br>",
        "published_at": "2020-04-30T15:29:33-05:00",
