    "https://www.beyondyouryaad.com": {
      "product": {
        "id": 8072262582575,
        "title": "GuruBox\u2122\ufe0f",
        "handle": "gurubox",
        "body_html": "<meta charset=\"UTF-8\">\n<p class=\"p1\"><span class=\"s1\">This unisex box comes packed with all your travel essentials so that you can take the guesswork out of packing! Equipped with TSA approved items, the GuruBox can be used for travel, to keep in your car, to stash in your desk at work, or to put in that spennanight bag </span><span class=\"s2\">\ud83c\udf1a</span><span class=\"s1\"> it\u2019s a great gift idea, so feel free to buy it for your friends, family, side piece, pastor, or neighbor. It even comes with a shot glass for those who want to stay ready for the turn up! Add this to your travel routine and take the stress work out of preparation.</span></p>\n<p class=\"p1\"><span class=\"s1\">Add-ons are available! Visit the products page to add more items to your box!</span></p>\n<p class=\"p1\"><strong><span class=\"s1\">Included:</span></strong></p>\n<ul class=\"ul1\">\n<li class=\"li1\">\n<span class=\"s2\"></span><span class=\"s3\">Leak proof Toiletry bag</span>\n</li>\n<li class=\"li1\">Advil (x4)</li>\n<li class=\"li1\">\n<span class=\"s2\"></span><span class=\"s3\">Mask (x4)</span>\n</li>\n<li class=\"li1\">\n<span class=\"s2\"></span><span class=\"s3\">Lotion</span>\n</li>\n<li class=\"li1\">\n<span class=\"s2\"></span><span class=\"s3\">Soap</span>\n</li>\n<li class=\"li1\">\n<span class=\"s2\"></span><span class=\"s3\">Tweezers</span>\n</li>\n<li class=\"li1\"><span class=\"s3\">Q Tips (x 5)</span></li>\n<li class=\"li1\">\n<span class=\"s2\"></span><span class=\"s3\">Nail clippers</span>\n</li>\n<li class=\"li1\">\n<span class=\"s2\"></span><span class=\"s3\">Nail file</span>\n</li>\n<li class=\"li1\">\n<span class=\"s2\"></span><span class=\"s3\">Mirror</span>\n</li>\n<li class=\"li1\">\n<span class=\"s2\"></span><span class=\"s3\">Toothpaste</span>\n</li>\n<li class=\"li1\">\n<span class=\"s2\"></span><span class=\"s3\">Mouthwash</span>\n</li>\n<li class=\"li1\">\n<span class=\"s2\"></span><span class=\"s3\">Toothbrush</span>\n</li>\n<li class=\"li1\">\n<span class=\"s2\"></span><span class=\"s3\">Floss (x 5)</span>\n</li>\n<li class=\"li1\">\n<span class=\"s2\"></span><span class=\"s3\">Tissue</span>\n</li>\n<li class=\"li1\">\n<span class=\"s2\"></span><span class=\"s3\">Stain remover (x4)</span>\n</li>\n<li class=\"li1\">\n<span class=\"s2\"></span><span class=\"s3\">Shot glass</span>\n</li>\n<li class=\"li1\">\n<span class=\"s2\"></span><span class=\"s3\">Razor</span>\n</li>\n<li class=\"li1\">\n<span class=\"s2\"></span><span class=\"s3\">Hand Sanitizer </span>\n</li>\n<li class=\"li1\">\n<span class=\"s2\"></span><span class=\"s3\">Lip balm</span>\n</li>\n<li class=\"li1\">\n<span class=\"s2\"></span><span class=\"s3\">Ear plugs</span>\n</li>\n</ul>",
        "published_at": "2023-01-14T18:28:48-05:00",
        "created_at": "2023-01-13T19:25:10-05:00",
        "updated_at": "2026-04-02T14:53:12-04:00",
