    "https://cfr-performance-retail.myshopify.com": {
      "product": {
        "id": 9392690626808,
        "title": "Plastic Screw-In Oil Cap Fits 1987-Up Chevy GM Car & Truck Chrome",
        "handle": "plastic-screw-in-oil-cap-fits-1987-up-chevy-gm-car-truck-chrome",
        "body_html": "<p data-start=\"0\" data-end=\"85\"><strong>CFR Performance Plastic Screw-In Oil Cap Fits 1987-Up Chevy GM Car &amp; Truck Chrome</strong></p>\n<p data-start=\"87\" data-end=\"359\"><strong data-start=\"87\" data-end=\"110\">Product Description</strong><br data-start=\"110\" data-end=\"113\">Chrome-finished plastic screw-in oil cap designed to fit 1987-up Chevy and GM car and truck engines. Manufactured from durable molded plastic, this oil cap provides a secure seal while adding a clean, upgraded chrome appearance to the engine bay.</p>\n<p data-start=\"361\" data-end=\"641\">The screw-in design ensures proper fitment and easy installation on compatible GM valve covers, helping prevent leaks and contamination. Ideal for replacing worn or damaged oil caps, this cap works well for stock replacements, restorations, or simple engine dress-up applications.</p>\n<p data-start=\"643\" data-end=\"1009\"><strong data-start=\"643\" data-end=\"659\">Key Features</strong><br data-start=\"659\" data-end=\"662\">\u2022 Compatibility: Fits 1987-up Chevy and GM car and truck engines<br data-start=\"726\" data-end=\"729\">\u2022 Material: Durable molded plastic<br data-start=\"763\" data-end=\"766\">\u2022 Finish: Chrome appearance for a clean, polished look<br data-start=\"820\" data-end=\"823\">\u2022 Style: Screw-in design for secure sealing and easy installation<br data-start=\"888\" data-end=\"891\">\u2022 Function: Replaces worn or damaged oil caps<br data-start=\"936\" data-end=\"939\">\u2022 Use Case: Stock replacement, restoration, or dress-up applications</p>\n<p data-start=\"1011\" data-end=\"1165\"><strong data-start=\"1011\" data-end=\"1029\">Specifications</strong><br data-start=\"1029\" data-end=\"1032\">\u2022 Material: Plastic<br data-start=\"1051\" data-end=\"1054\">\u2022 Finish: Chrome<br data-start=\"1070\" data-end=\"1073\">\u2022 Style: Screw-in oil cap<br data-start=\"1098\" data-end=\"1101\">\u2022 Fitment: 1987-up Chevy/GM vehicles<br data-start=\"1137\" data-end=\"1140\">\u2022 Quantity: One oil cap</p>",
        "published_at": "2026-01-29T09:36:33-08:00",
        "created_at": "2026-01-29T09:36:32-08:00",
        "updated_at": "2026-04-02T10:42:38-07:00",
