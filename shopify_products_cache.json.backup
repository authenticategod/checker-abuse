    "https://kamikaze-collection.store": {
      "product": {
        "id": 8728859934955,
        "title": "DETAILING COSMETIC APPLICATOR",
        "handle": "detailing-cosmetic-applicator-1",
        "body_html": "<p>The material and shape are designed to enable application of a thick, even coating to the smallest of areas as much as possible.<br data-mce-fragment=\"1\">Stress-free application is achieved by using three fingers.<br data-mce-fragment=\"1\">We use microfibers with ultra-fine bristles that do not scratch even solid black, which is used for cosmetics.<br data-mce-fragment=\"1\">\u3000<br data-mce-fragment=\"1\">This microfiber applicator can be used for all of our hardening system coatings and is especially suitable for applying STANCE RIM COAT and KIWAMI TIRE DRESSING.<br data-mce-fragment=\"1\"><br data-mce-fragment=\"1\">This is a select import product by the sub-brand \"THE DETAIL SUPPLY\".<br data-mce-fragment=\"1\">Material: Microfiber made of superfine hair material<br data-mce-fragment=\"1\">Made in China</p>",
        "published_at": "2025-03-26T22:37:57+09:00",
