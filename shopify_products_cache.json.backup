    "https://fcdlabels.com": {
      "product": {
        "id": 8101602591001,
        "title": "18-009",
        "handle": "18-009",
        "body_html": "<p><strong><span>SOLAR PV SYSTEM EQUIPPED WITH RAPID SHUTDOWN</span></strong></p>\n<p><strong>Solar Label 3\" x 4\" -\u00a0 Yellow, White &amp; Black</strong></p>\n<p><span>Per 2017 NEC 690.56(C)(1)(a)</span></p>\n<p><span>TURN RAPID SHUTDOWN SWITCH TO THE \u201cOFF\u201d POSITION TO SHUT DOWN PV SYSTEM AND REDUCE SHOCK HAZARD IN THE ARRAY</span></p>\n<ul>\n<li><span>Premium outdoor rated vinyl label</span></li>\n<li>2.75-mil Vinyl</li>\n<li>7 Year<span>\u00a0</span>Permanent Adhesive</li>\n<li>UL certified for UL 969\u00a0(USA)</li>\n<li>CSA certified for C22.2 No. 0.15 (Canada)</li>\n</ul>\n<p><span>*NEC code reference is for information only. Refer to the NEC 2011, 2014 or 2017 guide for complete descriptions.</span></p>\n<p><span>OK for exposure to:\u00a0Extreme Heat, Cold, Dry and Highly Humid Climate Conditions.<br></span><span>Temperature Rating: for use between\u00a0-40\u00b0F to +176\u00b0F</span></p>",
        "published_at": "2023-02-02T10:48:12-08:00",
