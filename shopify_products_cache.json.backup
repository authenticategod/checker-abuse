    "https://softtouchnailproducts.com": {
      "product": {
        "id": 9014361162023,
        "title": "7\" Standard Color Collection Mylar",
        "handle": "copy-of-7-standard-color-collection-green-mylar-120-120",
        "body_html": "<div style=\"text-align: center;\">\n<div style=\"text-align: center;\"><strong>Size: 7\" x 3/4\"</strong></div>\n<div style=\"text-align: center;\"><br></div>\n<div style=\"text-align: center;\"><strong>Made in USA</strong></div>\n<div style=\"text-align: center;\"><br></div>\n<div style=\"text-align: center;\">\n<p data-start=\"118\" data-end=\"211\" style=\"text-align: left;\"><strong data-start=\"118\" data-end=\"211\">Premium Nail Files \u2013 Washable, Reusable, Durable Emery Boards for Professional &amp; Home Use</strong></p>\n<p data-start=\"226\" data-end=\"464\" style=\"text-align: left;\">Upgrade your nail care routine with our <strong>high-quality nail files</strong>, designed for both professional nail techs and at-home users. These professional-grade emery boards feature a sturdy construction perfect for shaping acrylic, gel, or natural nails.</p>\n<p data-start=\"466\" data-end=\"1064\" style=\"text-align: left;\"><strong>Washable &amp; Reusable</strong> \u2013 Made with durable materials that withstand multiple uses. Simply rinse and sanitize after each use.<br data-start=\"587\" data-end=\"590\"><strong>Disinfectable &amp; Hygienic</strong> \u2013 Safe to use for salons or personal care. Easily cleaned with disinfectant or soap and water.<br data-start=\"709\" data-end=\"712\"><strong>Long-Lasting Durability </strong>\u2013 Built to last, our nail files don\u2019t bend, crack, or lose grit quickly.<br data-start=\"808\" data-end=\"811\"><strong>Versatile Performance</strong> \u2013 Ideal for shaping, shortening, smoothing, and refining nails.<br data-start=\"896\" data-end=\"899\"><strong>Comfortable to Hold</strong> \u2013 Easy to hold and control for precise filing, even during extended use.<br data-start=\"994\" data-end=\"997\"><strong>Use Wet or Dry</strong> \u2013 Works equally well in both wet and dry conditions.</p>\n<p data-start=\"1066\" data-end=\"1261\" style=\"text-align: left;\">Whether you\u2019re prepping nails for polish or removing gel, our reusable nail files deliver salon-quality results every time. Ideal for manicurists, pedicurists, nail salons, and DIY beauty lovers.</p>\n<p data-start=\"310\" data-end=\"591\" style=\"text-align: left;\">\u00a0</p>\n</div>\n</div>",
        "published_at": "2024-03-31T18:48:33-07:00",
        "created_at": "2024-03-03T19:31:08-08:00",
        "updated_at": "2026-04-02T11:53:12-07:00",
        "vendor": "Soft Touch\u00ae",
